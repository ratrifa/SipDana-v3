# Port tempat server akan berjalan
PORT=5000

# Konfigurasi Database MySQL (Sesuaikan dengan setup XAMPP Anda)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sip_dana

# Kunci rahasia untuk JWT (JSON Web Tokens)
JWT_SECRET=rahasia_super_aman_sipdana

# Kunci API OCR.space (daftar gratis di https://ocr.space/)
# Contoh: OCR_SPACE_API_KEY=helloworld


# Kunci API Roboflow Workflow (https://roboflow.com)
# Contoh: ROBOFLOW_API_KEY=your_roboflow_api_key
# Jika ingin mengubah endpoint workflow, gunakan:
# ROBOFLOW_WORKFLOW_URL=https://serverless.roboflow.com/<workspace>/workflows/<workflow>


# Opsi lain (jika diperlukan)
# NODE_ENV=development