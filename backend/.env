# Port tempat server akan berjalan
PORT=5000

# Konfigurasi Database MySQL (Sesuaikan dengan setup XAMPP Anda)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sip_dana

# Kunci rahasia untuk JWT (JSON Web Tokens)
JWT_SECRET=rahasia_super_aman_sipdana

# Kunci API Google Gemini / Generative AI (https://developers.google.com/)
# Contoh: GEMINI_API_KEY=your_google_api_key
# Atau gunakan GEMINI_MODEL untuk model lain (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_google_api_key
